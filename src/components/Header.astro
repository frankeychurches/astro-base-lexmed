---
import { Icon } from "astro-icon/components";
import { url } from "../utils/base";

const navLinks = [
  { href: "/", label: "Inicio" },
  { href: "/servicios", label: "Servicios" },
  { href: "/sobre-mi", label: "Sobre mí" },
  { href: "/contacto", label: "Contacto" },
];
---

<header
  class="w-full py-4 px-4 border-b border-gray-100 bg-white/95 backdrop-blur-sm sticky top-0 z-50"
  role="banner"
>
  <nav
    class="max-w-6xl mx-auto flex items-center justify-between"
    aria-label="Navegación principal"
  >
    <a
      href={url("/")}
      class="text-xl font-semibold text-[#1a2e4a] hover:text-[#14243b] transition-colors tracking-tight"
      aria-label="LexMed · Inicio"
    >
      LexMed
    </a>

    <!-- Mobile menu button -->
    <button
      type="button"
      class="md:hidden p-2 text-gray-600 hover:text-gray-900 focus:outline-none focus:ring-2 focus:ring-[#1a2e4a] focus:ring-offset-2 rounded-lg"
      aria-label="Abrir menú de navegación"
      aria-expanded="false"
      aria-controls="mobile-menu"
      id="mobile-menu-button"
    >
      <Icon name="tabler:menu-2" class="w-6 h-6" aria-hidden="true" />
    </button>

    <!-- Desktop navigation -->
    <ul class="hidden md:flex items-center gap-8" role="list">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={url(href)}
            class="text-gray-600 hover:text-gray-900 transition-colors text-sm font-medium"
            aria-current={Astro.url.pathname === url(href) ? 'page' : undefined}
          >
            {label}
          </a>
        </li>
      ))}
      <li>
        <a
          href="https://wa.me/34650403966"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-4 py-2 bg-[#1a2e4a] text-white text-sm font-semibold rounded-lg hover:bg-[#14243b] transition-colors"
          aria-label="Contactar por WhatsApp (abre WhatsApp)"
        >
          <Icon name="tabler:brand-whatsapp" class="w-4 h-4" aria-hidden="true" />
          WhatsApp
        </a>
      </li>
    </ul>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t border-gray-100 bg-white"
    role="menu"
    aria-labelledby="mobile-menu-button"
  >
    <ul class="flex flex-col py-2" role="list">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={url(href)}
            class="block px-4 py-3 text-gray-700 hover:bg-gray-50 hover:text-gray-900 transition-colors font-medium"
            role="menuitem"
            aria-current={Astro.url.pathname === url(href) ? 'page' : undefined}
          >
            {label}
          </a>
        </li>
      ))}
      <li class="px-4 py-3">
        <a
          href="https://wa.me/34650403966"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-4 py-2 bg-[#1a2e4a] text-white text-sm font-semibold rounded-lg hover:bg-[#14243b] transition-colors w-full justify-center"
          aria-label="Contactar por WhatsApp (abre WhatsApp)"
        >
          <Icon name="tabler:brand-whatsapp" class="w-4 h-4" aria-hidden="true" />
          Contactar por WhatsApp
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  // Mobile menu toggle functionality
  const menuButton = document.getElementById('mobile-menu-button');
  const mobileMenu = document.getElementById('mobile-menu');
  
  if (menuButton && mobileMenu) {
    menuButton.addEventListener('click', () => {
      const isExpanded = menuButton.getAttribute('aria-expanded') === 'true';
      menuButton.setAttribute('aria-expanded', String(!isExpanded));
      mobileMenu.classList.toggle('hidden');
    });

    // Close menu when clicking outside
    document.addEventListener('click', (e) => {
      if (
        !menuButton.contains(e.target as Node) &&
        !mobileMenu.contains(e.target as Node) &&
        !mobileMenu.classList.contains('hidden')
      ) {
        menuButton.setAttribute('aria-expanded', 'false');
        mobileMenu.classList.add('hidden');
      }
    });

    // Close menu on escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !mobileMenu.classList.contains('hidden')) {
        menuButton.setAttribute('aria-expanded', 'false');
        mobileMenu.classList.add('hidden');
        menuButton.focus();
      }
    });
  }
</script>
