---
import ScrollReveal from "./ScrollReveal.tsx";
import { Icon } from "astro-icon/components";

const services = [
  {
    icon: "tabler:stethoscope",
    title: "Valoración del Daño Corporal",
    description: "Evaluación pericial de lesiones y secuelas tras accidentes, con informe médico-legal para uso judicial.",
    href: "/servicios/valoracion-dano-corporal",
  },
  {
    icon: "tabler:file-certificate",
    title: "Informes Periciales",
    description: "Elaboración de informes médico-legales completos: nexo causal, días de baja, secuelas y conclusiones.",
    href: "/servicios/informes-periciales",
  },
  {
    icon: "tabler:shield-exclamation",
    title: "Negligencias Médicas",
    description: "Análisis de la lex artis y valoración del daño en reclamaciones por defectuosa asistencia sanitaria.",
    href: "/servicios/negligencias-medicas",
  },
  {
    icon: "tabler:car-crash",
    title: "Accidentes de Circulación",
    description: "Valoración conforme a la Ley 35/2015: lesiones, secuelas, incapacidad y gastos médicos reclamables.",
    href: "/servicios/accidentes-circulacion",
  },
  {
    icon: "tabler:clipboard-heart",
    title: "Incapacidades",
    description: "Valoración funcional para incapacidad temporal o permanente, con defensa en los Juzgados de lo Social.",
    href: "/servicios/incapacidades",
  },
  {
    icon: "tabler:scale",
    title: "Consultoría Médico-Legal",
    description: "Asesoramiento documentado a particulares y letrados en accidentes, malpraxis e incapacidades.",
    href: "/servicios/consultoria-medico-legal",
  },
];
---

<section id="servicios" class="max-w-6xl mx-auto px-4 py-20">
  <ScrollReveal client:idle delay={0.1}>
    <div class="text-center mb-14">
      <h2 class="text-4xl font-bold text-gray-900 mb-4">Servicios periciales</h2>
      <p class="text-lg text-gray-500 max-w-xl mx-auto">
        Más de 15 años de experiencia en valoración del daño corporal y peritaje médico-legal en Almería.
      </p>
    </div>
  </ScrollReveal>

  <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
    {services.map((service, index) => (
      <ScrollReveal client:idle delay={0.1 * (index + 1)} scale={true}>
        <a
          href={service.href}
          class="group flex flex-col p-6 bg-white rounded-xl border border-gray-200 hover:border-[#1a2e4a] hover:shadow-md transition-all"
        >
          <div class="w-11 h-11 bg-gray-50 group-hover:bg-[#1a2e4a]/10 rounded-lg flex items-center justify-center mb-4 transition-colors">
            <Icon name={service.icon} class="w-6 h-6 text-[#1a2e4a]" aria-hidden="true" />
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">{service.title}</h3>
          <p class="text-gray-500 text-sm leading-relaxed flex-1">{service.description}</p>
          <span class="mt-4 text-sm font-medium text-[#1a2e4a] group-hover:underline">
            Saber más →
          </span>
        </a>
      </ScrollReveal>
    ))}
  </div>
</section>
