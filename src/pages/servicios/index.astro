---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import CTA from "../../components/CTA.astro";
import ScrollReveal from "../../components/ScrollReveal.tsx";
import { Icon } from "astro-icon/components";
import { SITE } from "../../config/site.mjs";

const services = [
  {
    icon: "tabler:stethoscope",
    title: "Valoración del Daño Corporal",
    description:
      "Evaluación médico-legal de las consecuencias físicas y psíquicas de un traumatismo: días de baja, secuelas y nexo causal argumentados científicamente.",
    audience: ["Lesionados", "Abogados", "Aseguradoras"],
    href: "/servicios/valoracion-dano-corporal",
  },
  {
    icon: "tabler:file-certificate",
    title: "Informes Periciales",
    description:
      "Elaboración de informes médico-legales completos con exploración clínica, estado anterior, nexo causal, secuelas y conclusiones para uso judicial.",
    audience: ["Abogados", "Lesionados", "Tribunales"],
    href: "/servicios/informes-periciales",
  },
  {
    icon: "tabler:shield-exclamation",
    title: "Negligencias Médicas",
    description:
      "Análisis de la lex artis y preinforme de viabilidad para reclamaciones por defectuosa asistencia sanitaria en las vías penal, civil, contenciosa y social.",
    audience: ["Pacientes", "Abogados especialistas"],
    href: "/servicios/negligencias-medicas",
  },
  {
    icon: "tabler:car-crash",
    title: "Accidentes de Circulación",
    description:
      "Valoración conforme a la Ley 35/2015: lesiones, secuelas, incapacidad y gastos médicos actuales y futuros reclamables frente a aseguradoras.",
    audience: ["Víctimas de accidente", "Abogados de tráfico"],
    href: "/servicios/accidentes-circulacion",
  },
  {
    icon: "tabler:clipboard-heart",
    title: "Incapacidades",
    description:
      "Valoración funcional con criterios biomecánicos para incapacidad temporal o permanente, con defensa del informe en los Juzgados de lo Social.",
    audience: ["Trabajadores", "Letrados laboralistas"],
    href: "/servicios/incapacidades",
  },
  {
    icon: "tabler:scale",
    title: "Consultoría Médico-Legal",
    description:
      "Asesoramiento documentado a particulares y profesionales del Derecho sobre accidentes, incapacidades y malpraxis antes de iniciar un procedimiento.",
    audience: ["Particulares", "Abogados", "Empresas"],
    href: "/servicios/consultoria-medico-legal",
  },
];
---

<Layout
  title={`Servicios | ${SITE.title}`}
  description="Peritaje médico-legal en Almería: valoración del daño corporal, informes periciales, negligencias médicas, accidentes de tráfico, incapacidades y consultoría médico-legal."
  canonicalURL={`${SITE.url}/servicios`}
>
  <Header />
  <main id="main-content" role="main">

    <!-- Page hero -->
    <section class="max-w-6xl mx-auto px-4 pt-20 pb-14">
      <ScrollReveal client:load>
        <p class="text-sm font-semibold tracking-widest text-[#1a2e4a] uppercase mb-3">
          Áreas de actuación
        </p>
        <h1 class="text-5xl font-bold text-gray-900 mb-5">Servicios periciales</h1>
      </ScrollReveal>
      <ScrollReveal client:load delay={0.1}>
        <p class="text-xl text-gray-500 max-w-2xl leading-relaxed">
          El Dr. Francisco José Llave Gamero ofrece peritaje médico-legal en Almería desde 2009.
          Seleccione el servicio que necesita para obtener más información.
        </p>
      </ScrollReveal>
    </section>

    <!-- Services grid -->
    <section class="max-w-6xl mx-auto px-4 pb-20">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((service, index) => (
          <ScrollReveal client:idle delay={0.08 * (index + 1)} scale={true}>
            <a
              href={service.href}
              class="group flex flex-col p-7 bg-white rounded-2xl border border-gray-200 hover:border-[#1a2e4a] hover:shadow-lg transition-all duration-200 h-full"
            >
              <!-- Icon -->
              <div class="w-13 h-13 w-12 h-12 bg-[#1a2e4a]/8 group-hover:bg-[#1a2e4a]/15 rounded-xl flex items-center justify-center mb-5 transition-colors">
                <Icon name={service.icon} class="w-6 h-6 text-[#1a2e4a]" aria-hidden="true" />
              </div>

              <!-- Title & description -->
              <h2 class="text-lg font-semibold text-gray-900 mb-2 leading-snug">{service.title}</h2>
              <p class="text-gray-500 text-sm leading-relaxed flex-1">{service.description}</p>

              <!-- Audience tags -->
              <div class="flex flex-wrap gap-1.5 mt-4">
                {service.audience.map((tag) => (
                  <span class="text-xs px-2 py-0.5 bg-gray-100 text-gray-500 rounded-full">
                    {tag}
                  </span>
                ))}
              </div>

              <!-- CTA -->
              <span class="mt-5 inline-flex items-center gap-1 text-sm font-semibold text-[#1a2e4a] group-hover:gap-2 transition-all">
                Saber más
                <Icon name="tabler:arrow-right" class="w-4 h-4" aria-hidden="true" />
              </span>
            </a>
          </ScrollReveal>
        ))}
      </div>
    </section>

    <CTA />
  </main>
  <Footer />
</Layout>
